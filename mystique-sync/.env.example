# ─────────────────────────────────────────────────────────────────────────────
# mystique-sync environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
# Server-side service role key (NOT the anon key) so we can bypass RLS for
# admin operations like renaming hero SKUs.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-key

# ── Notion ──────────────────────────────────────────────────────────────────
# Internal integration token (starts with `secret_` or `ntn_`).
# Grant the integration access to the "Hero Product Lineup" database.
NOTION_KEY=ntn_your_integration_token
NOTION_HERO_PRODUCT_DB_ID=00000000000000000000000000000000

# ── Google Drive (service account) ──────────────────────────────────────────
# Share each target folder with DRIVE_CLIENT_EMAIL as Editor.
# DRIVE_PRIVATE_KEY: paste the full PEM key. Use literal "\n" between lines
# when stored on one logical line (env loader rewrites them to real newlines).
DRIVE_CLIENT_EMAIL=mystique-sync@your-project.iam.gserviceaccount.com
DRIVE_CLIENT_ID=000000000000000000000
DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...REPLACE...\n-----END PRIVATE KEY-----\n"

# Optional: parent Drive folder ID where the 01_..99_ sibling folders live.
# Leave empty to use the user's "My Drive" root.
DRIVE_ROOT_FOLDER_ID=

# ── Pipeline behavior ───────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
# Default concurrency for API-bound work (Drive listFiles, Notion writes).
SYNC_CONCURRENCY=3
