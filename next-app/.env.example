# =============================================================================
# Mystique storefront — copy this file to `.env.local` in this folder (next-app).
# `.env.local` is gitignored; this file is the single template for all integrations.
# Verify wiring: run `npm run dev`, then open http://localhost:3000/api/health/integrations
# =============================================================================

# --- Public site URL (Stripe redirects, magic-link redirects when Host header missing)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# SITE_URL=

# --- Supabase (catalog, auth, cart_items) — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Public key: legacy anon JWT (eyJ…) or new publishable key (sb_publishable_…).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: if the dashboard only shows “Publishable”, you can set this instead of ANON_KEY:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional server-only anon alias:
# SUPABASE_ANON_KEY=

# Service role (sb_secret_…) — server only; never NEXT_PUBLIC_*. Checkout + promos + newsletter.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe — Dashboard → Developers → API keys & Webhooks
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend (contact form + order confirmation emails) — https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Optional: where contact form notifications go (defaults: ORDERS_ADMIN_EMAIL → ORDER_NOTIFICATION_EMAIL → RESEND_FROM_EMAIL)
# CONTACT_NOTIFICATION_EMAIL=
# ORDERS_ADMIN_EMAIL=
# ORDER_NOTIFICATION_EMAIL=

# --- Diagnostics (production: set to 1 to expose GET /api/health/integrations)
# ENABLE_INTEGRATION_HEALTH=1

# --- Local E2E only (demo catalog when Supabase is not configured). Omit in production.
# ALLOW_MOCK_CATALOG=1
