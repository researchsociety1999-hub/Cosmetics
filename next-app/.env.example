# --- Google Analytics 4 (optional; omit = no analytics) ---
# Public GA4 Measurement ID from Google Analytics Web Data Stream Details
# Format: G-XXXXXXXXXX
# Set this in Vercel Production only; leave unset for local dev and Preview unless you want test traffic
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Copy to `next-app/.env.local` for local development (never commit secrets).

# --- Public site URL (magic links, Stripe return URLs, metadataBase, robots/sitemap) ---
# Production: set to your canonical origin.
# Vercel: set on Production + Preview; if omitted on Preview, VERCEL_URL is used when present.
# NEXT_PUBLIC_SITE_URL=https://mystique.city
# SITE_URL=https://mystique.city

# --- Supabase (catalog, auth, cart) ---
# Client / server URL (either name works):
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_URL=
#
# Public anon (or publishable) key — REQUIRED for magic-link auth and SSR sessions even if you set a service role below.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_ANON_KEY=
#
# Service role (server-only; never NEXT_PUBLIC_*). Needed for: promo validation, newsletter DB
# inserts, reliable order writes. Alias supported:
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=
#
# IMPORTANT: Do NOT put the service role key in NEXT_PUBLIC_SUPABASE_ANON_KEY — the app
# detects keys starting with sb_secret_* and disables the public client if found.
#
# Optional: extra image CDN hostnames for `next/image` + URL allowlist (comma-separated, no protocol).
# Must match entries you add for custom domains; rebuild after changing.
# NEXT_PUBLIC_IMAGE_REMOTE_HOSTS=cdn.mystique.city
#
# Catalog product thumbnails / gallery: OFF by default (branded placeholders). Set to 1 to show
# `image_url` / `extra_images` from Supabase when you have real product photography.
# NEXT_PUBLIC_SHOW_CATALOG_PRODUCT_PHOTOS=1

# --- Stripe (checkout) ---
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
#
# Webhook: Dashboard → Developers → Webhooks → endpoint
#   https://mystique.city/api/stripe/webhook
# Events at minimum: checkout.session.completed, checkout.session.async_payment_succeeded,
#   checkout.session.expired, checkout.session.async_payment_failed
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Allowed shipping countries: comma-separated ISO 3166-1 alpha-2 codes.
# Defaults to "US" if not set. Set multiple to enable international shipping.
# Example: NEXT_PUBLIC_STRIPE_ALLOWED_COUNTRIES=US,CA,GB,AU
# NEXT_PUBLIC_STRIPE_ALLOWED_COUNTRIES=US

# --- Resend (transactional email: orders, contact form, newsletter fallback) ---
# IMPORTANT: RESEND_FROM_EMAIL must be a verified custom-domain address.
# @gmail.com / @googlemail.com addresses are blocked by Resend and will silently
# disable all outbound email (orders, contact form, newsletter).
#
# If `SUPABASE_SERVICE_ROLE_KEY` is not set, newsletter signups still work by emailing
# the studio (requires RESEND_* below + optional CONTACT_NOTIFICATION_EMAIL).
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=orders@mystique.city
#
# Optional overrides (otherwise notifications fall back to RESEND_FROM_EMAIL):
# CONTACT_NOTIFICATION_EMAIL=hello@mystique.city
# ORDERS_ADMIN_EMAIL=orders@mystique.city
# ORDER_NOTIFICATION_EMAIL=orders@mystique.city

# --- Admin order dashboard (/admin/orders) — password gate, not linked from storefront ---
# MYSTIQUE_ADMIN_PASSWORD=choose-a-long-random-password
# MYSTIQUE_ADMIN_SECRET=32-or-more-random-chars-used-to-sign-the-admin-session-cookie

# --- Public studio email (Contact page sidebar + mailto fallbacks; omit until monitored) ---
# NEXT_PUBLIC_STUDIO_EMAIL=hello@mystique.city

# --- Social profiles (footer; omitted = hidden) ---
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://www.instagram.com/mystique.city
# NEXT_PUBLIC_SOCIAL_TIKTOK_URL=
# NEXT_PUBLIC_SOCIAL_X_URL=
# NEXT_PUBLIC_SOCIAL_TWITTER_URL=
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=
# NEXT_PUBLIC_SOCIAL_PINTEREST_URL=

# --- Prelaunch banner ---
# Controls the "Launching soon" banner shown at the top of every page.
# The banner ONLY renders when this is set to "1" AND there are 0 purchasable
# products in the catalog. Default (unset / empty / any other value) = hidden.
# Set to "0" or leave unset for a normal live storefront.
# MYSTIQUE_PRELAUNCH_BANNER=0

# --- Ritual Companion chat (OpenRouter) ---
# Server-only. Model is switched by changing OPENROUTER_MODEL only.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Optional dev / ops ---
# Expose /api/health/integrations in production (default: 404). Value must be "1".
# ENABLE_INTEGRATION_HEALTH=1
#
# Use embedded mock catalog instead of Supabase (local E2E / demos only; never production):
# ALLOW_MOCK_CATALOG=1
# ALLOW_MOCK_PRODUCTS=1
#
# Playwright catalog isolation: embedded mock products/categories even when Supabase URL is set.
# E2E_MOCK_CATALOG=1


