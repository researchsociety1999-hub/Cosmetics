# Copy to `.env.local` in this folder (next-app). Never commit real keys.
# See: https://supabase.com/dashboard/project/_/settings/api

# Project URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon / publishable key ONLY (JWT, usually starts with eyJ...).
# From: Supabase Dashboard → Settings → API → Project API keys → anon → public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional alias (same value as anon in most projects)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only: service role — do NOT prefix with NEXT_PUBLIC_
# SUPABASE_SERVICE_ROLE_KEY=
