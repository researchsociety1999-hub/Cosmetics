# ============================================================
# Secrets — never commit (use Vercel env dashboard + next-app/.env.example)
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# Next.js (app lives in next-app/)
# ============================================================
/next-app/.next/
/next-app/out/
/next-app/node_modules/

# ============================================================
# Playwright (root workspace)
# ============================================================
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
/next-app/test-results/
/next-app/playwright-report/
playwright-report/
test-results/

# ============================================================
# Generated / build artifacts — never commit these
# ============================================================
*.log
start-server.err.log
start-server.out.log
lint-results.txt
test-output.txt

# ============================================================
# Proof screenshots — generated by proof/capture-proof.mjs
# Regenerate on demand; do not commit (stale after every UI change)
# ============================================================
/proof/*.png
/proof/*.jpg
/proof/*.webp

